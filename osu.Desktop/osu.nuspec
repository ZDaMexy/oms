<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2011/08/nuspec.xsd">
    <metadata>
        <id>osulazer</id>
        <version>0.0.0</version>
        <title>OMS</title>
        <authors>OMS contributors</authors>
        <owners>OMS contributors</owners>
        <iconUrl>https://github.com/ppy/osu/blob/master/assets/lazer-nuget.png?raw=true</iconUrl>
        <icon>icon.png</icon>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>OMS - a BMS player based on osu!lazer</description>
        <releaseNotes>testing</releaseNotes>
        <copyright>Copyright (c) 2025 OMS contributors</copyright>
        <language>en-AU</language>
    </metadata>
    <files>
      <file src="**.exe" target="lib\net45\" exclude="**vshost**"/>
      <file src="**.dll" target="lib\net45\"/>
      <file src="**.config" target="lib\net45\"/>
      <file src="**.json" target="lib\net45\"/>
      <file src="**.ico" target="lib\net45\"/>
      <file src="icon.png" target=""/>
    </files>
</package>
